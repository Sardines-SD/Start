  <link rel="stylesheet" href="styler.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      min-height: 100vh;
      background: linear-gradient(135deg, #1a2a3a 0%, #2b5fa8 100%);
      color: #fff;
    }

    .terms-header {
      background: rgba(0,0,0,0.3);
      padding: 60px 20px;
      text-align: center;
    }

    .terms-header h1 {
      font-size: 48px;
      margin-bottom: 20px;
    }

    .container {
      max-width: 900px;
      margin: 0 auto;
      padding: 40px 20px;
    }

    .terms-card {
      background: rgba(255,255,255,0.1);
      border-radius: 20px;
      padding: 40px;
      backdrop-filter: blur(10px);
    }

    .terms-card h2 {
      color: #ffd700;
      margin: 30px 0 15px 0;
      font-size: 24px;
    }

    .terms-card h2:first-of-type {
      margin-top: 0;
    }

    .terms-card p {
      line-height: 1.6;
      margin-bottom: 15px;
      opacity: 0.95;
    }

    .terms-card ul {
      margin: 15px 0 15px 30px;
      line-height: 1.6;
    }

    .terms-card li {
      margin-bottom: 8px;
    }

    .effective-date {
      margin-top: 40px;
      padding-top: 20px;
      border-top: 1px solid rgba(255,255,255,0.2);
      font-size: 14px;
      text-align: center;
      opacity: 0.7;
    }

    .back-btn {
      display: inline-block;
      margin-top: 30px;
      padding: 10px 25px;
      background: rgba(255,255,255,0.2);
      color: #fff;
      text-decoration: none;
      border-radius: 30px;
      transition: all 0.3s ease;
    }

    .back-btn:hover {
      background: rgba(255,255,255,0.3);
    }

    footer {
      text-align: center;
      padding: 30px;
      background: rgba(0,0,0,0.3);
      margin-top: 40px;
    }
